# Copy to .env and adjust as needed.
#
# Local single-user development (default):
DATABASE_URL=sqlite:///app.db
#
# Hosted / multi-user (Postgres) — no code changes required, just swap the URL:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/job_app_assistant
#
# --- LLM layer (extraction / matching / cover letters) -----------------------
# Active provider: Groq (llama-3.3-70b-versatile). Free tier: 30 RPM, 14400 RPD.
# GROQ_API_KEY=your-groq-api-key   # from console.groq.com
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
# 8 RPM is conservative; Groq free tier allows 30 RPM for this model.
LLM_RPM=8
# Fallback: Google Gemini. Put key in .env, never here.
# GEMINI_API_KEY=your-google-ai-studio-key  (GEMINI_MODEL=gemini-2.0-flash)
#
# --- Scraper proxy (REQUIRED for any scraping) -------------------------------
# MANDATORY before running the scraper. ALL scraper browser traffic is routed
# through this endpoint so the user's real IP is never exposed to Seek (see
# CLAUDE.md "Networking policy"). The scraper is FAIL-CLOSED: if PROXY_SERVER is
# unset, app/scraper/browser.py refuses to launch a browser at all.
# PROXY_USERNAME / PROXY_PASSWORD are optional (only if your proxy needs auth).
PROXY_SERVER=http://proxy.example.com:8080
# PROXY_USERNAME=your-proxy-user
# PROXY_PASSWORD=your-proxy-pass
